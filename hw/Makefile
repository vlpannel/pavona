CUR_DIR := $(shell dirname $(realpath $(lastword $(MAKEFILE_LIST))))
PRJ_DIR := $(realpath ${CUR_DIR}/../)
SEED_MODE := testing

# macOS has a different implementation of xargs
UNAME_S := $(shell uname -s)
ifeq ($(UNAME_S),Darwin)
XARGS_REPLACE := -J '{}'
else
XARGS_REPLACE := -I '{}'
endif

# The IPs listed here have their collateral generated by an invocation of
# regtool triggered here; those not in this list have their reg collateral
# generated by ipgen or topgen.
IPS ?= acc                 \
       aes                 \
       adc_ctrl            \
       aon_timer           \
       csrng               \
       dma                 \
       edn                 \
       entropy_src         \
       flash_macro_wrapper \
       hmac                \
       i2c                 \
       keymgr              \
       keymgr_dpe          \
       kmac                \
       lc_ctrl             \
       mbx                 \
       otp_macro           \
       pattgen             \
       pwm                 \
       rom_ctrl            \
       rv_dm               \
       rv_timer            \
       sensor_ctrl         \
       soc_dbg_ctrl        \
       spi_device          \
       spi_host            \
       sram_ctrl           \
       sysrst_ctrl         \
       uart                \
       usbdev

TOPS ?= top_dragonfly top_egret top_scafi_deprecated

# Conditional flags: use VERBOSE=1 for adding -v flag.
VERBOSE ?= 0
toolflags ?=
ifeq ($(VERBOSE),1)
  toolflags      += -v
endif

dir_hjson = data
hjson_for_ip = ${PRJ_DIR}/hw/ip/$(1)/$(dir_hjson)/$(1).hjson

# IPs that have a directory in hw/ip and are not generated
local_ips := \
  $(foreach i,$(IPS),$(if $(wildcard $(call hjson_for_ip,$(i))),$(i)))

# Per-IP targets (all phonies)
ips_reg        = $(addsuffix _reg, $(local_ips))

# Per-top targets (all phonies)
tops_gen = $(addsuffix _gen,$(TOPS))
blk-hjson      = $(PRJ_DIR)/hw/ip/$*/$(dir_hjson)/$*.hjson
top_hjson = $(PRJ_DIR)/hw/$*/$(dir_hjson)/$*.hjson
top_complete_hjson = $(PRJ_DIR)/hw/$*/$(dir_hjson)/autogen/$*.gen.hjson
top_seed_hjson = $(PRJ_DIR)/hw/$*/$(dir_hjson)/$*_seed.$(SEED_MODE).hjson
top_complete_seed_hjson = $(PRJ_DIR)/hw/$*/$(dir_hjson)/autogen/$*.secrets.$(SEED_MODE).gen.hjson
top_chip_hjson = $(PRJ_DIR)/hw/$(TOPS)/$(dir_hjson)/$(TOPS).hjson

top: $(tops_gen)
$(tops_gen): %_gen:
	${PRJ_DIR}/util/topgen.py -t $(top_hjson) -s $(top_seed_hjson) -o ${PRJ_DIR}/hw/$*/ ${toolflags}
	(xbar_configs=$$(mktemp -d); \
	 ${PRJ_DIR}/util/gen_top_ipconfigs.py --ips xbar_main xbar_peri xbar_mbx xbar_dbg --xbars -s $(top_complete_seed_hjson) --outdir $$xbar_configs -t $(top_complete_hjson); \
	 for xbar_cfg in $$(ls $$xbar_configs); do \
	   ${PRJ_DIR}/util/tlgen.py --libname $* -t "$$xbar_configs"/"$$xbar_cfg" -o ${PRJ_DIR}/hw/$*/ip/$${xbar_cfg%".gen.hjson"}; \
	 done)

# This runs cmdgen on all md files of the repo using xargs for parallelism
cmdgen: top
	(cd ${PRJ_DIR}; find . -name "*.md" -print0 | \
	 xargs -0 -P 8 $(XARGS_REPLACE) ./util/cmdgen.py -u {})

regs:
$(ips_reg): %_reg:
	${PRJ_DIR}/util/regtool.py ${toolflags} -r $(blk-hjson)
	${PRJ_DIR}/util/regtool.py --sec-cm-testplan $(blk-hjson)

top_and_cmdgen: cmdgen

dvgen:
	${PRJ_DIR}/util/gen_ip_collection.py --flow sim_dv --tops top_egret top_dragonfly

all: cmdgen regs dvgen

.PHONY: all
