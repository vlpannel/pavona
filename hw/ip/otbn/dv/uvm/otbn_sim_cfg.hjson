// sim cfg file for the standard version of OTBN
{
  // Name of the sim cfg variant
  variant: standard

  // Import additional common sim cfg files.
  import_cfgs: ["{proj_root}/hw/ip/otbn/dv/uvm/otbn_base_sim_cfg.hjson"]

  smoke_dir: "{otbn_dir}/dv/smoke"

  // Fusesoc core file used for building the file list.
  fusesoc_core: lowrisc:dv:otbn_sim:0.1

  // Used to disable generation of pqc instructions with assembly gen
  pqc_enable: 0

  // Sets otbnsim to standard mode
  exports: [
    { PQC_EN: 0 },
  ]

  // exclusion files
  vcs_cov_excl_files: ["{proj_root}/hw/ip/otbn/dv/uvm/cov/otbn_standard_cov_excl.el"]
}
